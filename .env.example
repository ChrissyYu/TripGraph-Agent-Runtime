# Application
APP_NAME=TripPlan Multi-Agent
DEBUG=false
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=false

# LLM — default RuleBased; set QWEN_API_KEY + LLM_PROVIDER=qwen for real Qwen API
LLM_PROVIDER=rule_based
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Qwen (Alibaba Cloud Bailian) — only QWEN_API_KEY is required to enable real API
# LLM_PROVIDER=qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_PLANNER_MODEL=qwen3.7-plus
QWEN_CRITIC_MODEL=qwen3.7-plus
QWEN_REPLANNER_MODEL=qwen3.7-plus
QWEN_SUMMARIZER_MODEL=qwen3.6-flash
QWEN_ROUTER_MODEL=qwen3.6-flash
QWEN_TEMPERATURE=0
QWEN_MAX_TOKENS=2048
QWEN_TIMEOUT_SEC=120
# qwen3.7-plus smoke 建议 120–180；Planner 超时会 fallback RuleBased

LANGGRAPH_ENABLED=false

# Memory
SHORT_TERM_MAX_MESSAGES=50
LONG_TERM_STORE_PATH=./data/long_term_memory

# Streaming
SSE_RETRY_MS=3000
SSE_HEARTBEAT_INTERVAL_SEC=15

# Tool tracing
TOOL_TRACE_DEBUG=false
TOOL_MAX_RETRIES=2
TOOL_TIMEOUT_SEC=30.0
TOOL_ROUTER_STRATEGY=rule_based

# MCP tools (Phase 9B) — default off; enable for local MCP smoke
MCP_ENABLED=false
MCP_REQUIRED=false
MCP_SERVER_COMMAND=python
MCP_SERVER_ARGS=mcp_servers/trip_tools_server.py
MCP_TOOL_PREFIX=mcp_

# Tool routing policy (Phase 9C)
TOOL_POLICY_ENABLED=true
TOOL_POLICY_STRATEGY=planner_hint_first
TOOL_POLICY_MCP_FALLBACK_ENABLED=true
TOOL_POLICY_TRACE_ENABLED=true
TOOL_POLICY_DEFAULT_PROVIDER=builtin
TOOL_POLICY_RELIABILITY_STATS_PATH=./data/eval/tool_routing/tool_reliability_stats.json
TOOL_POLICY_SUCCESS_WEIGHT=0.7
TOOL_POLICY_LATENCY_WEIGHT=0.2
TOOL_POLICY_FALLBACK_WEIGHT=0.1

# Planner
PLANNER_MAX_RETRIES=2
PLAN_FAILURE_POLICY=retry
PLAN_STEP_MAX_RETRIES=2
PLAN_MAX_REPLAN_ATTEMPTS=1

# Plan context compression
PLAN_CONTEXT_COMPRESSION_ENABLED=true
PLAN_CONTEXT_MAX_CHARS=2000

# Execution critic
PLAN_EXECUTION_CRITIC_ENABLED=true
PLAN_CRITIC_REPLAN_ENABLED=true
PLAN_CRITIC_MAX_REPLAN_ATTEMPTS=2
# Optional: smoke script only — caps replan attempts (e.g. SMOKE_MAX_REPLAN_ATTEMPTS=1)

# Graph runtime (Phase 4)
GRAPH_RUNTIME_ENABLED=true
GRAPH_MAX_ITERATIONS=50

# Persistence (Phase 5)
PERSISTENCE_ENABLED=false
PERSISTENCE_DB_PATH=./data/persistence/executions.db

# Observability (Phase 6)
METRICS_ENABLED=false
LOG_JSON=false
ENABLE_JSON_LOG=false
METRICS_PROMPT_USD_PER_1K=0.005
METRICS_COMPLETION_USD_PER_1K=0.015

# Evaluation (Phase 7)
EVAL_ENABLED=true
# deterministic_eval = RuleBased LLM (CI/regression); real_llm_eval = use LLM_PROVIDER; auto = follow provider
EVAL_MODE=deterministic_eval
EVAL_STORE_PATH=./data/eval
EVAL_DEFAULT_SEED=42
EVAL_REGRESSION_THRESHOLD=-0.05
